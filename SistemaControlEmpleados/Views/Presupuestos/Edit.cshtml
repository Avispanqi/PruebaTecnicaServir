@model Presupuesto
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var departamentos = ViewBag.Departamentos as IEnumerable<SelectListItem>;
}

<h1 class="page-title">@(Model.Id == 0 ? "Nueva asignación" : "Editar asignación")</h1>

<div class="panel p-4">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="DepartamentoId" class="form-label">Departamento *</label>
            <select asp-for="DepartamentoId" asp-items="departamentos" class="form-select" required>
                <option value="0">Seleccione...</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Monto" class="form-label">Monto *</label>
            <input asp-for="Monto" type="number" step="0.01" min="0.01" class="form-control" required />
        </div>

        <div class="mb-3">
            <label asp-for="FechaAsignacion" class="form-label">Fecha</label>
            <input asp-for="FechaAsignacion" type="date" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Observacion" class="form-label">Observación</label>
            <textarea asp-for="Observacion" class="form-control"></textarea>
        </div>

        <button class="btn btn-pink">Guardar</button>
        <a class="btn btn-light" asp-action="Index">Volver</a>
    </form>
</div>
